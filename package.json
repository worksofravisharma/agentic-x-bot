{
  "name": "bot-ai-widget",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4301 --project=widget-element",
    "start:app": "ng serve --port 4301 --project=widget-element",
    "start:element": "ng serve --port 4301 --project=widget-element",
    "build:element": "ng build --configuration=production --project=widget-element --build-optimizer --named-chunks=true --output-hashing=none && node build.js",
    "build:bundle": "node build.js"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^14.2.0",
    "@angular/compiler": "^14.2.0",
    "@angular/core": "^14.2.0",
    "@angular/forms": "^14.3.0",
    "@angular/platform-browser": "^14.2.0",
    "@angular/platform-browser-dynamic": "^14.2.0",
    "bootstrap": "^5.3.8",
    "rxjs": "~7.5.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.11.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^14.2.13",
    "@angular/cli": "~14.2.13",
    "@angular/compiler-cli": "^14.2.0",
    "@types/node": "^14.18.63",
    "fs-extra": "^11.3.2",
    "typescript": "~4.7.2"
  }
